generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String?  @unique
  email     String   @unique
  role      String   @default("USER") // USER | COMPANY
  onboarded Boolean  @default(false)  // has the account picked its type?
  firstName String?
  lastName  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyProfile CompanyProfile?
  ownedProducts  UserProduct[]
  sessions       DiagnosticSession[]
  posts          Post[]
  ratings        Rating[]
}

model CompanyProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
  threads  Thread[]
}

model Product {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  category    String   @default("General")
  description String?
  imageUrl    String?
  mossIndexId String?  // = "product-<id>"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   CompanyProfile      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  manuals   Manual[]
  owners    UserProduct[]
  sessions  DiagnosticSession[]
  ratings   Rating[]
  spareParts SparePart[]
  recalls   Recall[]
  schedules MaintenanceSchedule[]
}

model Manual {
  id         String   @id @default(cuid())
  productId  String
  title      String
  fileUrl    String?
  kind       String   @default("pdf") // pdf | doc | link | video
  chunkCount Int      @default(0)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model UserProduct {
  id           String    @id @default(cuid())
  userId       String
  productId    String
  serialNumber String?
  purchasedAt  DateTime?
  createdAt    DateTime  @default(now())

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  product  Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  warranty Warranty?
  tasks    MaintenanceTask[]

  @@unique([userId, productId])
}

model Warranty {
  id            String   @id @default(cuid())
  userProductId String   @unique
  expiresAt     DateTime
  provider      String?
  createdAt     DateTime @default(now())

  userProduct UserProduct @relation(fields: [userProductId], references: [id], onDelete: Cascade)
}

model MaintenanceSchedule {
  id          String @id @default(cuid())
  productId   String
  title       String
  description String?
  intervalDays Int    @default(180)

  product Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  tasks   MaintenanceTask[]
}

model MaintenanceTask {
  id            String    @id @default(cuid())
  userProductId String
  scheduleId    String?
  title         String
  dueAt         DateTime
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  userProduct UserProduct          @relation(fields: [userProductId], references: [id], onDelete: Cascade)
  schedule    MaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
}

model Recall {
  id        String   @id @default(cuid())
  productId String
  title     String
  severity  String   @default("notice") // notice | safety | recall
  body      String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model SparePart {
  id         String  @id @default(cuid())
  productId  String
  name       String
  partNumber String?
  price      Float?
  forSymptom String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Rating {
  id        String   @id @default(cuid())
  productId String
  userId    String
  stars     Int      @default(5)
  title     String?
  body      String?
  issueTag  String?  // common problem tagging for health score
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
}

model DiagnosticSession {
  id          String    @id @default(cuid())
  userId      String?
  productId   String
  issueTag    String?
  resolved    Boolean   @default(false)
  rating      Int?
  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // user | assistant
  content   String
  meta      String?  // JSON: citations, difficulty, etc.
  createdAt DateTime @default(now())

  session DiagnosticSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

/* ---- Reddit-style community threads ---- */

model Thread {
  id          String   @id @default(cuid())
  companyId   String
  slug        String
  title       String   // the "subreddit" / sub-thread name
  description String?
  parentId    String?  // companies can create sub-threads
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   Thread?        @relation("ThreadTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Thread[]       @relation("ThreadTree")
  posts    Post[]

  @@unique([companyId, slug])
}

model Post {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  title     String?
  content   String
  mediaUrl  String?
  audioUrl  String?
  parentId  String?  // nested replies (multi-user discussion)
  isOfficial Boolean @default(false) // company employee answer
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread  Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author  User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Post?  @relation("PostTree", fields: [parentId], references: [id], onDelete: SetNull)
  replies Post[] @relation("PostTree")
}
